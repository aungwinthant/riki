                }
              }
            }
          }
        },
        "delete": {
          "operationId": "deleteUser",
          "summary": "Delete a user by ID",
          "tags": [
            "users"
          ],
          "parameters": [
            {
              "name": "userId",
              "in": "path",
              "required": true,
              "schema": {
                "type": "integer",
                "minimum": 1
              }
            }
          ],
          "responses": {
